# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/academic_platform?retryWrites=true&w=majority
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@iam.gserviceaccount.com
FIREBASE_API_KEY=your-firebase-api-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8000
MODEL_NAME=sentence-transformers/paraphrase-MiniLM-L6-v2

# API Configuration
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@academicplatform.com

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES=pdf,pptx,docx,doc,txt

# Logging
LOG_LEVEL=debug
