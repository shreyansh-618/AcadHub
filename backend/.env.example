NODE_ENV=development
PORT=3000

# Database
DB_URI=mongodb+srv://username:password@cluster.mongodb.net/academic_platform?retryWrites=true&w=majority

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@iam.gserviceaccount.com

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Gemini + Vector Search
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-1.5-flash
EMBEDDING_DIMENSIONS=3072
VECTOR_SEARCH_INDEX_NAME=resource_embedding_index
MIN_EMBEDDING_CHARS=100
EMBEDDING_REQUEST_DELAY_MS=1000
EMBEDDING_RETRY_JOB_ENABLED=true
EMBEDDING_RETRY_INTERVAL_MS=60000
EMBEDDING_RETRY_BATCH_SIZE=5
ENABLE_UPLOAD_ENRICHMENT=false

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,pptx,docx,doc,txt

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Socket.io
SOCKET_IO_PING_INTERVAL=25000
SOCKET_IO_PING_TIMEOUT=20000
