# AI Service Environment Variables

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/acadhub?retryWrites=true&w=majority

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# Embedding Model
MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_HUB_TOKEN=hf_your_token_here
MODEL_LOAD_STRATEGY=startup
MODEL_LOAD_TIMEOUT_SECONDS=180
MODEL_LOAD_RETRIES=3
MODEL_LOAD_RETRY_BASE_DELAY_SECONDS=2

# Caching
CACHE_TTL_SECONDS=86400

# API Configuration
PORT=8000
CORS_ORIGIN=http://localhost:5173,http://localhost:5000,http://localhost:3000
BACKEND_URL=http://localhost:5000
REQUEST_TIMEOUT_SECONDS=45
MAX_REQUEST_SIZE_BYTES=2097152
MAX_INPUT_LENGTH=5000
DB_CONNECT_TIMEOUT_SECONDS=10
DB_CONNECT_RETRIES=3
DB_CONNECT_RETRY_BASE_DELAY_SECONDS=2
OPENAI_RETRIES=3
OPENAI_RETRY_BASE_DELAY_SECONDS=2
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=60
AI_RATE_LIMIT_REQUESTS=15
AI_SERVICE_API_KEY=
METRICS_API_KEY=
WORKER_COUNT=2

# Logging
LOG_LEVEL=info
